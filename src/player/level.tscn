[sub_resource type="GDScript" id="GDScript_g8cci"]
script/source = "@tool # 👈 Add this right here!
extends Node

@onready var player: CharacterBody3D = $Player
@onready var phantom_camera: PhantomCamera3D = $PlayerPhantomCamera

func _ready() -> void:
	# CRITICAL SAFETY CHECK: Tool scripts run in the editor AND the game.
	# We only want to assign paths when the actual game is running!
	if Engine.is_editor_hint():
		return
		
	if player and phantom_camera:
		phantom_camera.set_follow_target(player)
"

